# ─── Firebase (server-side only — never exposed to the browser bundle) ───────
# Get these from Firebase Console → Project Settings → Your Apps → Web App
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ─── Backend API ──────────────────────────────────────────────────────────────
# The Go Gin server base URL. NEXT_PUBLIC is intentional — just a hostname.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

NEXT_PUBLIC_ADMIN_EMAILS=your_email@gmail.com,other@google.com
