PORT=8080
REDIS_ADDR=redis:6379
NATS_URL=nats://nats:4222
GIN_MODE=debug
DB_URL=postgres://user:password@localhost:5432/votes?sslmode=disable

# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
# The server uses Application Default Credentials (ADC) — no key file needed.
#
# Local dev:
#   1. Install gcloud CLI: https://cloud.google.com/sdk/docs/install
#   2. Run: gcloud auth application-default login
#   3. Grant your Google account the Firebase Authentication Admin role in IAM.
#   That is all — ADC picks up your credentials automatically.
#
# GCP (Cloud Run / GKE):
#   Attach a service account to the Cloud Run service and grant it:
#   roles/firebaseauth.admin
#   No environment variable or key file is needed.
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: run `make setup-run` to set this user as first super-admin
# (user must already exist in Firebase Auth)
BOOTSTRAP_SUPER_ADMIN_EMAIL=
